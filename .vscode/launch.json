{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CLI - LPCDocs to Markdown (Thresh, Hooks, Lang, Format)",
      "type": "node",
      "request": "launch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/src/cli.js",
      "args": [
        "--maxConcurrent",
        "3",
        "--debug",
        "--debugLevel",
        "5",
        "--include",
        "/mud/frogdice/thresh/lib/adm/simul_efun/**/*.c",
        "--output",
        "examples/output/markdown/",
        "--parser",
        "examples/node_modules_test/bedoc-lpcdoc-parser/bedoc-lpcdoc-parser.js",
        "--printer",
        "examples/node_modules_test/bedoc-markdown-printer/bedoc-markdown-printer.js",
        "--hooks",
        "examples/hooks/lpc-markdown-hooks.js",
        "--hookTimeout",
        "300000", // 5 minutes
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "CLI - LPCDocs to Markdown (Thresh, Single, Hooks, Lang, Format)",
      "type": "node",
      "request": "launch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/src/cli.js",
      "args": [
        "--debug",
        "--debugLevel",
        "5",
        "--include",
        "/mud/frogdice/thresh/lib/adm/simul_efun/signal.c",
        "--output",
        "examples/output/markdown/",
        "--parser",
        "examples/node_modules_test/bedoc-lpcdoc-parser/bedoc-lpcdoc-parser.js",
        "--printer",
        "examples/node_modules_test/bedoc-markdown-printer/bedoc-markdown-printer.js",
        "--hooks",
        "examples/hooks/lpc-markdown-hooks.js"
      ],
      "console": "integratedTerminal"
    },
  ]
}
